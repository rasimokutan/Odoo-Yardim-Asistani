<templates xml:space="preserve">
    <t t-name="odoo_help_assistant.ChatbotAction">
        <div class="o_oha">
            <header class="o_oha__topbar">
                <div class="o_oha__brand">
                    <span class="o_oha__brand_logo">AI</span>
                    <div class="o_oha__brand_text">
                        <h1>Odoo Yardım Asistanı</h1>
                        <p>Yerel yapay zeka ile adım adım Türkçe yardım</p>
                    </div>
                </div>
                <button class="o_oha__btn o_oha__btn--primary"
                        t-on-click="createSession"
                        t-att-disabled="state.creatingSession or !state.canUseChatbot">
                    <span class="o_oha__btn_plus">+</span>
                    <span>Yeni Sohbet</span>
                </button>
            </header>

            <t t-if="state.loading">
                <div class="o_oha__status">
                    <div class="o_oha__spinner"/>
                    <span>Sohbet ortamı yükleniyor...</span>
                </div>
            </t>
            <t t-elif="!state.canUseChatbot">
                <div class="o_oha__status o_oha__status--error">
                    Bu yardım asistanını kullanma yetkiniz bulunmuyor. Sistem yöneticinizle görüşün.
                </div>
            </t>
            <t t-elif="!state.chatbotEnabled">
                <div class="o_oha__status o_oha__status--warning">
                    Yardım asistanı ayarlardan pasif durumda. Yönetici kullanıcı ayarları kontrol etmelidir.
                </div>
            </t>
            <t t-else="">
                <div class="o_oha__layout">
                    <aside class="o_oha__sidebar">
                        <div class="o_oha__sidebar_head">
                            <h2>Sohbetler</h2>
                            <span class="o_oha__badge" t-esc="state.sessions.length"/>
                        </div>
                        <t t-if="!state.sessions.length">
                            <div class="o_oha__empty">
                                Henüz bir sohbet yok. Yeni bir sohbet başlatarak Odoo hakkında soru sorabilirsiniz.
                            </div>
                        </t>
                        <div class="o_oha__session_list">
                            <t t-foreach="state.sessions" t-as="session" t-key="session.id">
                                <button
                                    class="o_oha__session_item"
                                    t-att-class="{ 'o_oha__session_item--active': session.id === state.currentSessionId }"
                                    t-att-data-session-id="session.id"
                                    t-on-click="onSessionClick"
                                >
                                    <span class="o_oha__session_dot"/>
                                    <span class="o_oha__session_main">
                                        <strong t-esc="session.name"/>
                                        <span class="o_oha__session_preview" t-esc="session.last_message_preview || 'Mesaj bekleniyor'"/>
                                    </span>
                                    <span class="o_oha__session_time" t-esc="formatTimestamp(session.last_message_at)"/>
                                </button>
                            </t>
                        </div>
                    </aside>

                    <section class="o_oha__chat">
                        <div class="o_oha__chat_head">
                            <span class="o_oha__avatar o_oha__avatar--assistant o_oha__avatar--lg">
                                <t t-out="ASSISTANT_GLYPH"/>
                            </span>
                            <div class="o_oha__chat_head_text">
                                <h2 t-esc="currentSession ? currentSession.name : 'Yeni sohbet'"/>
                                <p>Türkçe yanıt verir, emin olmadığı durumda bunu belirtir.</p>
                            </div>
                        </div>

                        <t t-if="state.error">
                            <div class="o_oha__inline_error" t-esc="state.error"/>
                        </t>

                        <div class="o_oha__messages" t-ref="messageList">
                            <t t-if="!displayedMessages.length">
                                <div class="o_oha__welcome">
                                    <div class="o_oha__welcome_icon">
                                        <t t-out="ASSISTANT_GLYPH"/>
                                    </div>
                                    <h3>Size nasıl yardımcı olabilirim?</h3>
                                    <p>Bir örnek soruyla başlayın ya da kendi sorunuzu yazın.</p>
                                    <div class="o_oha__suggestions">
                                        <t t-foreach="exampleQuestions" t-as="example" t-key="example_index">
                                            <button class="o_oha__chip"
                                                    t-att-data-question="example"
                                                    t-on-click="onExampleClick"
                                                    t-esc="example"/>
                                        </t>
                                    </div>
                                </div>
                            </t>
                            <t t-foreach="displayedMessages" t-as="message" t-key="message.id">
                                <div t-att-class="'o_oha__row o_oha__row--' + message.role">
                                    <span t-att-class="'o_oha__avatar o_oha__avatar--' + message.role">
                                        <t t-out="message.role === 'user' ? USER_GLYPH : ASSISTANT_GLYPH"/>
                                    </span>
                                    <div t-att-class="'o_oha__bubble o_oha__bubble--' + message.role">
                                        <div class="o_oha__bubble_meta">
                                            <strong t-esc="message.role === 'user' ? 'Siz' : 'Asistan'"/>
                                            <span t-esc="formatTimestamp(message.timestamp)"/>
                                        </div>
                                        <t t-if="message.pending">
                                            <div class="o_oha__typing"><span/><span/><span/></div>
                                        </t>
                                        <t t-else="">
                                            <div class="o_oha__bubble_body" t-esc="message.content"/>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <div class="o_oha__composer">
                            <textarea
                                class="o_oha__composer_input"
                                placeholder="Sorunuzu buraya yazın. Örnek: Stokta bir transferi nasıl doğrularım?"
                                t-model="state.draft"
                                t-on-keydown="onDraftKeydown"
                                t-att-disabled="state.sending"
                            />
                            <button class="o_oha__send"
                                    t-on-click="onSendMessage"
                                    t-att-disabled="state.sending"
                                    aria-label="Gönder">
                                <t t-out="SEND_GLYPH"/>
                            </button>
                        </div>
                        <p class="o_oha__composer_hint">Enter ile gönder · Shift+Enter ile yeni satır</p>
                    </section>
                </div>
            </t>
        </div>
    </t>
</templates>
