<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_odoo_help_assistant" model="ir.actions.client">
        <field name="name">Odoo Yardim Asistani</field>
        <field name="tag">odoo_help_assistant.main</field>
        <field name="target">current</field>
    </record>

    <record id="view_odoo_chatbot_session_tree" model="ir.ui.view">
        <field name="name">odoo.chatbot.session.tree</field>
        <field name="model">odoo.chatbot.session</field>
        <field name="arch" type="xml">
            <list string="Sohbet Oturumlari">
                <field name="name"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="message_count"/>
                <field name="last_message_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_odoo_chatbot_session_form" model="ir.ui.view">
        <field name="name">odoo.chatbot.session.form</field>
        <field name="model">odoo.chatbot.session</field>
        <field name="arch" type="xml">
            <form string="Sohbet Oturumu">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="user_id" readonly="1"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_message_at" readonly="1"/>
                            <field name="message_count" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Mesajlar">
                        <field name="message_ids" readonly="1">
                            <list string="Mesajlar">
                                <field name="create_date" string="Zaman"/>
                                <field name="role"/>
                                <field name="user_id"/>
                                <field name="content"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_odoo_chatbot_session_manager" model="ir.actions.act_window">
        <field name="name">Sohbet Gecmisi</field>
        <field name="res_model">odoo.chatbot.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_odoo_help_assistant_root"
        name="Yardim Asistani"
        sequence="40"
        groups="base.group_user"
    />

    <menuitem
        id="menu_odoo_help_assistant_chat"
        name="Sohbet"
        parent="menu_odoo_help_assistant_root"
        action="action_odoo_help_assistant"
        sequence="1"
        groups="base.group_user"
    />

    <menuitem
        id="menu_odoo_help_assistant_history"
        name="Gecmis Sohbetler"
        parent="menu_odoo_help_assistant_root"
        action="action_odoo_chatbot_session_manager"
        sequence="10"
        groups="base.group_system"
    />
</odoo>
